# HTTP Server Configuration
# Copy this to .env OR use config.toml (see config.example.toml).
# Env vars override config.toml values.
# Required vars if not using config.toml:

# Domain for TLS certificate
DOMAIN=your-domain.com

# Email for Let's Encrypt
EMAIL=your-email@example.com

# Directory to store certificates
CERT_DIR=certs/

# Use Let's Encrypt staging (true) or production (false)
USE_STAGING=true

# Server host and port
HOST=0.0.0.0
PORT=443

# HSTS (Strict-Transport-Security) — set to 0 to disable
# HSTS_MAX_AGE=31536000
# HSTS_INCLUDE_SUBDOMAINS=true

# Reverse proxy routes (JSON map of path prefix -> upstream URL)
# Unmatched requests return 404. Forwarded requests preserve method, headers, and body.
# PROXY_ROUTES='{"/api":"http://localhost:3000","/app":"http://localhost:5173"}'

# Path to TOML config file (default: config.toml)
# CONFIG_PATH=/etc/http-server/config.toml
